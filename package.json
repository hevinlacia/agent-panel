{
  "name": "agent-panel",
  "version": "0.1.0",
  "description": "Local web dashboard for pi coding agent sessions, requirements, schedulers, and reports.",
  "type": "module",
  "scripts": {
    "dev": "bun run build:dashboard && tsx watch src/server.tsx",
    "start": "bun run build:dashboard && tsx src/server.tsx",
    "typecheck": "bun run typecheck:server && bun run typecheck:web",
    "test": "node --test --import tsx tests/*.test.ts",
    "build:dashboard": "vite build",
    "typecheck:web": "tsc -p web/tsconfig.json --noEmit",
    "typecheck:server": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "9.3.0",
    "@fastify/swagger": "9.8.0",
    "@fastify/swagger-ui": "6.1.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/websocket": "11.3.0",
    "@kitajs/html": "^4.2.13",
    "@sinclair/typebox": "0.34.50",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fastify": "5.10.0",
    "framer-motion": "^12.42.2",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.24.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22"
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty"
  ]
}

{
  "name": "agent-panel",
  "version": "0.1.0",
  "description": "Local web dashboard for pi coding agent sessions, requirements, schedulers, and reports.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.tsx",
    "start": "tsx src/server.tsx",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "9.3.0",
    "@fastify/swagger": "9.8.0",
    "@fastify/swagger-ui": "6.1.0",
    "@fastify/type-provider-typebox": "6.1.0",
    "@fastify/websocket": "11.3.0",
    "@kitajs/html": "^4.2.13",
    "@sinclair/typebox": "0.34.50",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fastify": "5.10.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=22"
  },
  "trustedDependencies": [
    "esbuild",
    "node-pty"
  ]
}
